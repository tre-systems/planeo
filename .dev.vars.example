# Worker-side secrets for `npm run preview` and `wrangler dev`.
# Copy to .dev.vars and fill in. Never commit .dev.vars.
# In production these are set with `wrangler secret put <NAME>`.
#
# Client build-time variables are separate: anything prefixed VITE_
# (VITE_WORLD_WRITE_TOKEN, VITE_TTS_ENABLED) is inlined into the browser
# bundle by Vite — set those in .env / .env.local (or the shell), not here.

# Gemini text + vision (required for AI agents to think/speak).
GOOGLE_AI_API_KEY=

# Google Cloud service-account JSON (single line) for Cloud TTS. Optional.
GOOGLE_APP_CREDS_JSON=

# Optional write gate: with WORLD_WRITE_TOKEN set, only bearers may POST
# events or invoke the billable Gemini routes; everyone else is a read-only
# spectator. Build trusted-writer clients with the same value in
# VITE_WORLD_WRITE_TOKEN (in .env.local).
# WORLD_WRITE_TOKEN=

# Optional server-side TTS kill switch: "false" makes /api/tts refuse.
# TTS_ENABLED=false

# Optional Gemini model overrides (defaults: gemini-3.1-flash-lite).
# GOOGLE_TEXT_MODEL=
# GOOGLE_VISION_MODEL=

# Optional rolling one-hour budgets for the billable routes.
# RATE_LIMIT_AI_HOURLY=2000
# RATE_LIMIT_TTS_HOURLY=240
