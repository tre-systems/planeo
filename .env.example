# Environment Variables Example
# -----------------------------
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# --- AI (required for agents to think and chat) ---

# Google Generative AI key for the Gemini text + vision models.
# Get one from Google AI Studio: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=

# Public base URL of the app. Server actions POST AI chat back to /api/events
# through this. Use http://localhost:3000 for local development.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Text-to-Speech (optional) ---

# Google Cloud service-account JSON for Cloud TTS (Chirp3 voices), as a SINGLE
# line. Required only for live speech. Create a key, then: jq -c . < key.json
GOOGLE_APP_CREDS_JSON=

# Set to "false" to disable Text-to-Speech. Enabled by default.
NEXT_PUBLIC_TTS_ENABLED=

# --- World configuration (optional) ---

# JSON array of agents, e.g. [{"id":"ai-agent-1","displayName":"Orion"}].
# Defaults to two agents, Orion and Nova, when unset.
AI_AGENTS_CONFIG=

# Maximum number of AI agents given starting positions. Defaults to 0.
TOTAL_AGENTS=

# Number of interactive cubes to spawn. Defaults to 5.
NUMBER_OF_BOXES=
